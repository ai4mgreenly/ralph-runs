#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/ralph-runs/run - Pipeline orchestrator for concurrent goal execution
#
# Usage: ralph-runs --max N [--duration DURATION]
#
# Picks up queued goals, spawns ralphs in isolated clones, collects results,
# merges to main on success, pushes to GitHub as backup, retries on failure.
#
# Arguments:
#   --max N            Maximum concurrent ralphs (required)
#   --duration DUR     Time budget per ralph (e.g., 4h, 200m)
#
# Model and reasoning are read from goal tickets; defaults: sonnet, med
#
# Exit code: 0 on clean shutdown, 130 on interrupt
#

require 'json'
require 'optparse'
require 'fileutils'
require 'set'
require 'open3'
require 'erb'
require 'timeout'
require 'shellwords'

SCRIPT_DIR = File.dirname(File.realpath(__FILE__))
PROJECT_ROOT = File.expand_path('../..', SCRIPT_DIR)
RALPH_DIR = ENV['RALPH_DIR'] || File.join(ENV['HOME'], '.local', 'state', 'ralph')
CLONE_DIR = File.join(RALPH_DIR, 'clones')
LOG_DIR = File.join(RALPH_DIR, 'logs')
GOAL_DIR = File.join(RALPH_DIR, 'goals')
LOG_FILE = File.join(LOG_DIR, 'ralph-runs.log')
RALPH_SCRIPT = File.join(SCRIPT_DIR, '..', 'ralph', 'run')
NOTIFY_SCRIPT = File.join(SCRIPT_DIR, '..', 'notify', 'run')
GOAL_LIST_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-list', 'run')
GOAL_GET_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-get', 'run')
GOAL_START_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-start', 'run')
GOAL_DONE_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-done', 'run')
GOAL_STUCK_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-stuck', 'run')
GOAL_QUEUE_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-queue', 'run')
GOAL_COMMENT_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-comment', 'run')
GOAL_COMMENTS_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-comments', 'run')
GOAL_RETRY_SCRIPT = File.join(SCRIPT_DIR, '..', 'goal-retry', 'run')
MAX_RETRIES = 3

def init_log
  FileUtils.mkdir_p(LOG_DIR)
  FileUtils.rm_f(LOG_FILE)
  @log_file = File.open(LOG_FILE, 'w')
end

def log(message)
  timestamp = Time.now.strftime('%Y-%m-%d %H:%M:%S')
  line = "[#{timestamp}] #{message}"
  puts line
  $stdout.flush
  @log_file.puts(line)
  @log_file.flush
end

def run_script(script, *args)
  cmd = [script] + args
  stdout = IO.popen(cmd, err: '/dev/null', &:read)
  return nil unless $?.exitstatus == 0

  JSON.parse(stdout)
rescue JSON::ParserError
  nil
end

def post_comment(goal_id, body)
  IO.popen([GOAL_COMMENT_SCRIPT, goal_id.to_s], 'r+', err: '/dev/null') do |io|
    io.write(body)
    io.close_write
    io.read
  end
rescue StandardError
  nil
end

def get_goal_comments(goal_id)
  result = run_script(GOAL_COMMENTS_SCRIPT, goal_id.to_s)
  (result && result['ok'] && result['items']) || []
end

def fetch_attachments(goal_id)
  result = run_script('goal-attachments', goal_id.to_s)
  return [] unless result && result['ok']

  items = result['items'] || []
  return [] if items.empty?

  items.filter_map do |att|
    att_id = att['id']
    att_name = att['name'] || att_id.to_s
    next unless att_id

    att_data = run_script('goal-attachment-get', goal_id.to_s, att_id.to_s)
    next unless att_data && att_data['ok'] && att_data['body']

    { name: att_name, body: att_data['body'] }
  end
rescue StandardError
  []
end

def build_retry_context(goal_body, comments, attempt, max)
  parts = [goal_body]

  parts << "\n## Retry Context"
  parts << "\n**Attempt #{attempt} of #{max + 1}.** A previous attempt failed post-merge checks. Do NOT redo the work from scratch. Fix whatever is failing so all checks pass."

  unless comments.empty?
    parts << "\n### Failure Log"
    comments.each do |comment|
      created = comment['created_at'] || ''
      parts << "\n*#{created}:*"
      parts << comment['body']
      parts << ""
    end
  end

  parts << "\n### Required Action"
  parts << "1. Read the Failure Log above to understand what failed."
  parts << "2. Run `.ralph/check` (or the specific failing checks) to see the actual error output."
  parts << "3. Fix whatever is failing — even if the failure is pre-existing or unrelated to the goal. All checks must pass. It is your job to make them pass."
  parts << "4. Do not delete or modify `.ralph/check`."
  parts << "5. Run `.ralph/check` again to confirm it passes before declaring DONE."

  parts.join("\n")
end


def clone_repo(remote_url, org, repo, goal_id)
  dest = File.join(CLONE_DIR, org, repo, goal_id.to_s)
  FileUtils.mkdir_p(File.dirname(dest))
  system('git', 'clone', '--quiet', remote_url, dest, out: '/dev/null', err: '/dev/null')
  return nil unless $?.exitstatus == 0

  setup_goal_branch(dest, goal_id)
  dest
end

def delete_clone(org, repo, goal_id)
  dest = File.join(CLONE_DIR, org, repo, goal_id.to_s)
  FileUtils.rm_rf(dest) if Dir.exist?(dest)
end

def delete_goal_dir(goal_id)
  dest = File.join(GOAL_DIR, goal_id.to_s)
  FileUtils.rm_rf(dest) if Dir.exist?(dest)
end

def setup_goal_branch(clone_dir, goal_id)
  branch = "goal-#{goal_id}"

  # Check if branch exists in remote
  ls_output = IO.popen(['git', 'ls-remote', '--heads', 'origin', branch],
                        chdir: clone_dir, err: '/dev/null', &:read)
  branch_exists = ls_output && !ls_output.strip.empty?

  if branch_exists
    # Fetch and checkout the existing branch, then rebase onto current main
    system('git', 'fetch', 'origin', branch, chdir: clone_dir, out: '/dev/null', err: '/dev/null')
    system('git', 'checkout', branch, chdir: clone_dir, out: '/dev/null', err: '/dev/null')

    unless system('git', 'rebase', 'origin/main', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      # Rebase conflict — discard branch and start fresh from main
      system('git', 'rebase', '--abort', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      system('git', 'checkout', 'main', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      system('git', 'branch', '-D', branch, chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      system('git', 'checkout', '-b', branch, chdir: clone_dir, out: '/dev/null', err: '/dev/null')
    end
  else
    # First attempt — create branch from HEAD (currently on main after clone)
    system('git', 'checkout', '-b', branch, chdir: clone_dir, out: '/dev/null', err: '/dev/null')
  end
end

def push_goal_branch(clone_dir, goal_id)
  branch = "goal-#{goal_id}"
  system('git', 'push', '-f', 'origin', branch,
         chdir: clone_dir, out: '/dev/null', err: '/dev/null')
end

MERGE_MAX_ATTEMPTS = 10

def load_direnv_env(dir)
  return nil unless File.exist?(File.join(dir, '.envrc'))

  system('/usr/bin/direnv', 'allow', dir, out: '/dev/null', err: '/dev/null')
  json_output = IO.popen(['/usr/bin/direnv', 'export', 'json'], chdir: dir, err: '/dev/null', &:read)
  return nil unless $?.exitstatus == 0 && !json_output.strip.empty?

  ENV.to_h.merge(JSON.parse(json_output))
rescue JSON::ParserError
  nil
end

def merge_to_main(goal_id, title, clone_dir, direnv_env = nil)
  MERGE_MAX_ATTEMPTS.times do |attempt|
    log "Goal ##{goal_id} merge attempt #{attempt + 1}/#{MERGE_MAX_ATTEMPTS}" if attempt > 0

    # Fetch latest main from bare repo
    unless system('git', 'fetch', 'origin', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      log "Goal ##{goal_id} git fetch failed"
      return :merge_failed
    end

    # Rebase work onto current origin/main
    unless system('git', 'rebase', 'origin/main', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      log "Goal ##{goal_id} rebase failed"
      system('git', 'rebase', '--abort', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      return :merge_failed
    end

    # Check for conflict markers (unmerged paths)
    git_status = IO.popen(['git', 'status', '--porcelain'], chdir: clone_dir, err: '/dev/null', &:read)
    if git_status.lines.any? { |l| l =~ /^U/ }
      log "Goal ##{goal_id} rebase produced conflicts"
      system('git', 'rebase', '--abort', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      return :conflict
    end

    # Check if there are commits beyond origin/main
    git_log = IO.popen(['git', 'log', '--oneline', 'origin/main..HEAD'],
                        chdir: clone_dir, err: '/dev/null', &:read)
    if git_log.strip.empty?
      log "Goal ##{goal_id} no changes to merge"
      return :no_changes
    end

    # Run .ralph/check if it exists
    check_script = File.join(clone_dir, '.ralph', 'check')
    if File.exist?(check_script)
      # Log git state before running check
      log "Goal ##{goal_id} .ralph/check pre-run: #{git_log.lines.count} commit(s) above origin/main"
      log "Goal ##{goal_id} git log origin/main..HEAD:\n#{git_log.strip}"
      log "Goal ##{goal_id} git status: #{git_status.strip.empty? ? '(clean)' : git_status.strip}"

      # Log key environment vars
      env_to_use = direnv_env || ENV.to_h
      log "Goal ##{goal_id} check env: direnv_loaded=#{!direnv_env.nil?} PATH=#{env_to_use['PATH'].to_s[0, 120]}"

      check_cmd = direnv_env ? [direnv_env, check_script] : [check_script]
      check_stdout, check_stderr, check_status = Open3.capture3(*check_cmd, chdir: clone_dir)
      unless check_status.success?
        log "Goal ##{goal_id} .ralph/check failed (exit #{check_status.exitstatus})"
        log "Goal ##{goal_id} check stdout: #{check_stdout.strip.empty? ? '(empty)' : check_stdout.strip}"
        log "Goal ##{goal_id} check stderr: #{check_stderr.strip.empty? ? '(empty)' : check_stderr.strip}"
        combined_output = [check_stdout.strip, check_stderr.strip].reject(&:empty?).join("\n\n--- stderr ---\n")
        return [:check_failed, combined_output]
      end
    end

    # Squash all commits since origin/main into a single commit
    unless system('git', 'reset', '--soft', 'origin/main', chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      log "Goal ##{goal_id} failed to reset for squash"
      return :merge_failed
    end

    unless system('git', 'commit', '-m', "Goal ##{goal_id}: #{title}",
                  chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      log "Goal ##{goal_id} failed to commit squashed changes"
      return :merge_failed
    end

    # Push to bare repo — this is the atomic "claim" on main
    if system('git', 'push', 'origin', 'HEAD:main',
              chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      # Delete goal branch now that work is on main (best-effort; may not exist)
      system('git', 'push', 'origin', '--delete', "goal-#{goal_id}",
             chdir: clone_dir, out: '/dev/null', err: '/dev/null')
      return :ok
    end

    # Push failed — main diverged, loop back to fetch and rebase
    log "Goal ##{goal_id} push failed (main diverged), retrying"
  end

  log "Goal ##{goal_id} merge loop exhausted (#{MERGE_MAX_ATTEMPTS} attempts)"
  :merge_failed
end

def push_to_github(org, repo)
  bare_repo = "/mnt/store/git/#{org}/#{repo}"
  system('git', '--git-dir', bare_repo, 'push', 'origin', 'main',
         out: '/dev/null', err: '/dev/null')
end

def notify(title, message)
  payload = JSON.generate(title: title, message: message)
  IO.popen(NOTIFY_SCRIPT, 'r+') do |io|
    io.write(payload)
    io.close_write
    io.read
  end
rescue StandardError
  # Notification failure is non-fatal
end

def format_elapsed(seconds)
  hours, remainder = seconds.divmod(3600)
  mins, secs = remainder.divmod(60)
  if hours > 0
    "#{hours}h#{mins}m#{secs}s"
  elsif mins > 0
    "#{mins}m#{secs}s"
  else
    "#{secs}s"
  end
end

def goal_label(goal_id, repo_info)
  "Goal ##{goal_id} (#{repo_info[:nwo]})"
end

def kill_with_escalation(pid, pgid = nil, timeout_secs = 5)
  target = pgid ? -pgid : pid
  Process.kill('INT', target) rescue nil
  deadline = Time.now + timeout_secs
  loop do
    break if (Process.waitpid(pid, Process::WNOHANG) rescue nil)
    break if Time.now >= deadline
    sleep 0.5
  end
  Process.kill('KILL', target) rescue nil
  Process.wait(pid) rescue nil
end

def startup_cleanup
  # Recover orphaned running goals (left by a previous crash or kill -9)
  result = run_script(GOAL_LIST_SCRIPT, '--status', 'running')
  orphaned = (result && result['ok'] && result['items']) || []

  if orphaned.any?
    log "Startup: found #{orphaned.size} orphaned running goal(s), recovering..."
    orphaned.each do |goal|
      goal_id = goal['id']
      run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
      run_script(GOAL_RETRY_SCRIPT, goal_id.to_s)
      log "Startup: Goal ##{goal_id} → re-queued (was running)"
    end
  end

  # Push goal branches from stale clones, then remove them
  if Dir.exist?(CLONE_DIR)
    Dir.glob(File.join(CLONE_DIR, '*', '*', '*')).each do |clone_path|
      next unless Dir.exist?(clone_path)

      parts = clone_path.delete_prefix(CLONE_DIR + '/').split('/')
      next unless parts.size == 3

      org, repo_name, goal_id_str = parts
      branch = "goal-#{goal_id_str}"

      # Only push if clone is on the goal branch
      current_branch = begin
        IO.popen(['git', 'rev-parse', '--abbrev-ref', 'HEAD'],
                 chdir: clone_path, err: '/dev/null', &:read).strip
      rescue StandardError
        ''
      end

      next unless current_branch == branch

      if system('git', 'push', '-f', 'origin', branch,
                chdir: clone_path, out: '/dev/null', err: '/dev/null')
        log "Startup: pushed #{branch} from stale clone #{org}/#{repo_name}/#{goal_id_str}"
      else
        log "Startup: WARNING failed to push #{branch} from stale clone #{org}/#{repo_name}/#{goal_id_str}"
      end
    end

    stale = Dir.children(CLONE_DIR)
    unless stale.empty?
      log "Startup: removing #{stale.size} stale entr#{stale.size == 1 ? 'y' : 'ies'} under clones/"
      FileUtils.rm_rf(Dir.glob(File.join(CLONE_DIR, '*')))
      log "Startup: clone directory cleaned"
    end
  end
end

def main(options)
  init_log

  max_slots = options[:max]
  duration = options[:duration]

  log "Starting orchestrator (max #{max_slots} ralphs)"
  log "Duration: #{duration || 'unlimited'}"

  startup_cleanup

  # State tracking
  running = {}                # pid => {goal_id:, title:, dir:, started_at:, stream_thread:, wait_thread:, repo:}
  retries = Hash.new(0)       # goal_id => retry count
  attempted = Set.new         # goal_id
  completed_count = 0
  last_queued_count = nil
  last_running_count = nil
  last_completed_count = nil
  @shutting_down = false

  # Ctrl+C handler
  trap('INT') do
    @shutting_down = true
  end

  loop do
    # ── Shutdown ──
    if @shutting_down
      log 'Shutting down...'
      running.each do |pid, info|
        kill_with_escalation(pid, info[:pgid])
        info[:stream_thread]&.join rescue nil

        ri = info[:repo]
        goal_id = info[:goal_id]

        # Requeue — operator interrupt is not a failure
        run_script(GOAL_QUEUE_SCRIPT, goal_id.to_s)
        log "#{goal_label(goal_id, ri)} → queued (interrupted)"

        if push_goal_branch(info[:dir], goal_id)
          delete_clone(ri[:org], ri[:repo], goal_id)
          log "Cleaned up clones/#{ri[:org]}/#{ri[:repo]}/#{goal_id}/ and goals/#{goal_id}/"
        else
          log "#{goal_label(goal_id, ri)} WARNING: failed to push goal-#{goal_id} branch; clone preserved"
        end
        delete_goal_dir(goal_id)
      end
      log 'Done'
      break
    end

    # ── Detect externally-aborted goals ──
    aborted_pids = []
    running.each do |pid, info|
      goal_id = info[:goal_id]
      goal_data = run_script(GOAL_GET_SCRIPT, goal_id.to_s)
      next unless goal_data && goal_data['ok']
      next if goal_data['status'] == 'running'

      # Goal is no longer running — aborted externally (e.g., via goal-abort)
      ri = info[:repo]
      log "#{goal_label(goal_id, ri)} externally aborted (status: #{goal_data['status']}), killing process"
      kill_with_escalation(pid, info[:pgid])
      info[:stream_thread]&.join rescue nil
      if push_goal_branch(info[:dir], goal_id)
        delete_clone(ri[:org], ri[:repo], goal_id)
        log "#{goal_label(goal_id, ri)} cleaned up (aborted)"
      else
        log "#{goal_label(goal_id, ri)} WARNING: failed to push goal-#{goal_id} branch; clone preserved (aborted)"
      end
      delete_goal_dir(goal_id)
      aborted_pids << pid
    end
    aborted_pids.each { |pid| running.delete(pid) }

    next if @shutting_down

    # ── Collect finished ralphs ──
    finished = []
    running.each do |pid, info|
      unless info[:wait_thread].alive?
        status = info[:wait_thread].value
        finished << [pid, status]
      end
    end

    finished.each do |pid, status|
      info = running.delete(pid)
      goal_id = info[:goal_id]
      ri = info[:repo]
      nwo = ri[:nwo]
      org = ri[:org]
      repo_name = ri[:repo]
      elapsed = format_elapsed((Time.now - info[:started_at]).to_i)
      gl = goal_label(goal_id, ri)

      # Wait for stream thread to finish writing all output
      info[:stream_thread]&.join

      if status.exitstatus == 0
        log "#{gl} ralph finished (exit 0, #{elapsed})"

        result = merge_to_main(goal_id, info[:title], info[:dir], info[:direnv_env])

        # Normalize result: extract check output if check failed
        check_output = nil
        if result.is_a?(Array)
          result, check_output = result
        end

        case result
        when :no_changes
          log "#{gl} no changes to merge"
          # Delete goal branch from bare repo (best-effort; may not exist)
          system('git', 'push', 'origin', '--delete', "goal-#{goal_id}",
                 chdir: info[:dir], out: '/dev/null', err: '/dev/null')
          run_script(GOAL_DONE_SCRIPT, goal_id.to_s)
          completed_count += 1
          log "#{gl} → done"
          notify("#{gl} done", "\"#{info[:title]}\" completed in #{elapsed}")
          delete_clone(org, repo_name, goal_id)
          delete_goal_dir(goal_id)
        when :conflict, :check_failed, :merge_failed
          log "#{gl} #{result}, treating as failure"
          comment = "Merge failed (#{result})"
          comment += "\n\n#{check_output}" if check_output && !check_output.empty?
          post_comment(goal_id, comment)
          retries[goal_id] += 1

          if retries[goal_id] > MAX_RETRIES
            run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
            log "#{gl} → stuck (#{retries[goal_id]} retries exhausted)"
            notify("#{gl} stuck", "\"#{info[:title]}\" failed #{retries[goal_id]} times")
          else
            run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
            run_script(GOAL_RETRY_SCRIPT, goal_id.to_s)
            log "#{gl} → re-queued (retry #{retries[goal_id]}/#{MAX_RETRIES})"
          end
          if push_goal_branch(info[:dir], goal_id)
            delete_clone(org, repo_name, goal_id)
          else
            log "#{gl} WARNING: failed to push goal-#{goal_id} branch; clone preserved"
          end
          delete_goal_dir(goal_id)
        when :ok
          log "#{gl} merged to main"
          if push_to_github(org, repo_name)
            log "#{gl} pushed to GitHub"
          else
            log "#{gl} GitHub push failed (non-fatal)"
          end
          run_script(GOAL_DONE_SCRIPT, goal_id.to_s)
          completed_count += 1
          log "#{gl} → done"
          notify("#{gl} done", "\"#{info[:title]}\" completed in #{elapsed}")
          delete_clone(org, repo_name, goal_id)
          delete_goal_dir(goal_id)
        end
      else
        log "#{gl} ralph finished (exit #{status.exitstatus}, #{elapsed})"
        retries[goal_id] += 1

        if retries[goal_id] > MAX_RETRIES
          run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
          log "#{gl} → stuck (#{retries[goal_id]} retries exhausted)"
          notify("#{gl} stuck", "\"#{info[:title]}\" failed #{retries[goal_id]} times")
          if push_goal_branch(info[:dir], goal_id)
            delete_clone(org, repo_name, goal_id)
          else
            log "#{gl} WARNING: failed to push goal-#{goal_id} branch; clone preserved"
          end
          delete_goal_dir(goal_id)
        else
          # Post failure context, mark stuck, requeue
          post_comment(goal_id, "Ralph failed (exit #{status.exitstatus}, attempt #{retries[goal_id]}/#{MAX_RETRIES})")
          run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
          run_script(GOAL_RETRY_SCRIPT, goal_id.to_s)
          log "#{gl} failed → re-queued (retry #{retries[goal_id]}/#{MAX_RETRIES})"
          if push_goal_branch(info[:dir], goal_id)
            delete_clone(org, repo_name, goal_id)
          else
            log "#{gl} WARNING: failed to push goal-#{goal_id} branch; clone preserved"
          end
          delete_goal_dir(goal_id)
        end
      end
    end

    # ── Fill open slots ──
    result = run_script(GOAL_LIST_SCRIPT, '--status', 'queued', '--ready')
    all_queued = (result && result['ok'] && result['items']) || []
    all_queued.each do |g|
      g['_repo'] = { org: g['org'], repo: g['repo'], nwo: "#{g['org']}/#{g['repo']}" }
    end

    queued_count = all_queued.size
    running_count = running.size

    if queued_count != last_queued_count || running_count != last_running_count || completed_count != last_completed_count
      status_parts = []
      status_parts << "#{queued_count} queued"
      status_parts << "#{running_count} running"
      status_parts << "#{completed_count} completed"
      log status_parts.join(', ')
      last_queued_count = queued_count
      last_running_count = running_count
      last_completed_count = completed_count
    end

    available_slots = max_slots - running.size

    if available_slots > 0
      # Sort by goal id ascending (FIFO)
      all_queued.sort_by! { |g| g['id'] }

      # Partition into untried and retried goals for fairness
      untried = all_queued.reject { |g| attempted.include?(g['id']) }
      retried = all_queued.select { |g| attempted.include?(g['id']) }

      # Dispatch untried goals first, then retried
      candidates = (untried + retried).first(available_slots)

      candidates.each do |goal|
        ri = goal['_repo']
        nwo = ri[:nwo]
        org = ri[:org]
        remote_url = "/mnt/store/git/#{org}/#{ri[:repo]}"
        repo_name = ri[:repo]
        goal_id = goal['id']
        title = goal['title']
        gl = goal_label(goal_id, ri)

        # Transition to running (race-safe: skip on failure)
        start_result = run_script(GOAL_START_SCRIPT, goal_id.to_s)
        unless start_result && start_result['ok']
          log "#{gl} failed to start (already claimed?), skipping"
          next
        end
        log "#{gl} \"#{title}\" → running (slot #{running.size + 1}/#{max_slots})"

        # Clone
        clone_dir = clone_repo(remote_url, org, repo_name, goal_id)
        unless clone_dir
          log "#{gl} clone failed, marking stuck and requeuing"
          run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
          run_script(GOAL_RETRY_SCRIPT, goal_id.to_s)
          next
        end
        log "#{gl} cloned to clones/#{org}/#{repo_name}/#{goal_id}/"

        # Load .envrc environment if present
        direnv_env = load_direnv_env(clone_dir)
        log "#{gl} loaded .envrc environment" if direnv_env

        # Fetch goal body
        goal_data = run_script(GOAL_GET_SCRIPT, goal_id.to_s)
        unless goal_data && goal_data['ok']
          log "#{gl} failed to fetch goal body, marking stuck and requeuing"
          run_script(GOAL_STUCK_SCRIPT, goal_id.to_s)
          run_script(GOAL_RETRY_SCRIPT, goal_id.to_s)
          delete_clone(org, repo_name, goal_id)
          next
        end

        # Build goal file — augment with retry context if comments exist
        goal_body = goal_data['body']
        if retries[goal_id] > 0
          comments = get_goal_comments(goal_id)
          goal_body = build_retry_context(goal_body, comments, retries[goal_id], MAX_RETRIES)
        end

        # Fetch and inline attachments (supplementary — failure does not block)
        begin
          attachments = fetch_attachments(goal_id)
          if attachments.any?
            log "#{gl} inlining #{attachments.size} attachment(s)"
            attachments.each do |att|
              goal_body += "\n\n## Attachment: #{att[:name]}\n\n#{att[:body]}"
            end
          end
        rescue StandardError => e
          log "#{gl} attachment fetch error (continuing): #{e.message}"
        end

        # Write goal body into GOAL_DIR
        goal_dir = File.join(GOAL_DIR, goal_id.to_s)
        FileUtils.mkdir_p(goal_dir)
        goal_file = File.join(goal_dir, 'goal.md')
        File.write(goal_file, goal_body)

        # Use goal-specific model/reasoning if provided, otherwise default to sonnet/med
        goal_model = goal_data['model'] || 'sonnet'
        goal_reasoning = goal_data['reasoning'] || 'med'
        log "#{gl} using model: #{goal_model}, reasoning: #{goal_reasoning}"

        # Spawn ralph with real-time log streaming
        ralph_log = File.join(goal_dir, 'ralph.log')
        ralph_args = [
          RALPH_SCRIPT,
          "--goal=#{goal_file}",
          '--log-mode',
          "--model=#{goal_model}",
          "--reasoning=#{goal_reasoning}",
          "--name=#{title}"
        ]
        ralph_args << "--duration=#{duration}" if duration

        # Use Open3.popen2e to stream output with proper wait_thread handling
        log_file = File.open(ralph_log, 'w')
        ralph_cmd = direnv_env ? [direnv_env, *ralph_args] : ralph_args
        stdin, stdout_and_stderr, wait_thread = Open3.popen2e(*ralph_cmd, chdir: clone_dir, pgroup: true)
        stdin.close  # We don't need stdin
        pid = wait_thread.pid
        pgid = Process.getpgid(pid) rescue pid

        # Stream output in a background thread
        stream_thread = Thread.new do
          begin
            stdout_and_stderr.each_line do |line|
              log_file.puts(line)
              log_file.flush
            end
          ensure
            stdout_and_stderr.close
            log_file.close
          end
        end

        log "#{gl} ralph started (pid #{pid}, log: goals/#{goal_id}/ralph.log)"

        # Mark this goal as attempted for fairness tracking
        attempted.add(goal_id)

        running[pid] = {
          goal_id: goal_id,
          title: title,
          dir: clone_dir,
          started_at: Time.now,
          stream_thread: stream_thread,
          wait_thread: wait_thread,
          repo: ri,
          direnv_env: direnv_env,
          pgid: pgid
        }
      end
    end

    # ── Sleep ──
    sleep 5
  end
end

# ─────────────────────────────────────────────────────────────
# CLI
# ─────────────────────────────────────────────────────────────

options = {}

OptionParser.new do |opts|
  opts.banner = <<~BANNER
    ralph-runs - Pipeline coordinator for concurrent goal execution

    Usage: ralph-runs --max N [options]

    Model and reasoning are read from goal tickets; defaults: sonnet, med
  BANNER

  opts.on('--max=N', Integer, 'Maximum concurrent ralphs (required)') do |n|
    options[:max] = n
  end

  opts.on('--duration=DURATION', 'Time budget per ralph (e.g., 4h, 200m)') do |d|
    options[:duration] = d
  end

  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit
  end
end.parse!

if options[:max].nil? || options[:max] < 1
  $stderr.puts 'Error: --max=N is required (must be >= 1)'
  $stderr.puts 'Usage: ralph-runs --max N [options]'
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main(options)
  rescue Interrupt
    exit 130
  end
end
